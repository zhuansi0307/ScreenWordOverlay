<Window x:Class="ScreenWordOverlay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="屏幕逐词翻译覆盖"
        Width="480" Height="680"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanMinimize"
        Topmost="True">

    <Border Background="{StaticResource BackgroundBrush}"
            CornerRadius="12"
            Margin="8"
            MouseLeftButtonDown="Border_MouseLeftButtonDown">

        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.5" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="36"/>
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="Border_MouseLeftButtonDown">
                <Grid Margin="16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="📋" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="屏幕逐词翻译覆盖" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button x:Name="BtnMinimize" Content="─" Width="36" Height="36"
                                FontSize="12" Background="Transparent" Foreground="{StaticResource TextSecondaryBrush}"
                                Click="BtnMinimize_Click" Padding="0"/>
                        <Button x:Name="BtnClose" Content="✕" Width="36" Height="36"
                                FontSize="12" Background="Transparent" Foreground="{StaticResource TextSecondaryBrush}"
                                Click="BtnClose_Click" Padding="0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 主内容区 -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16,12">
                <StackPanel>

                    <!-- 操作区 -->
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="操作说明" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}" Margin="0,0,0,12"/>

                            <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="22"
                                       Foreground="{StaticResource TextSecondaryBrush}">
                                <Run Text="&#x2022; 右键拖拽"/>
                                <Run Text=" → " Foreground="{StaticResource AccentBrush}"/>
                                <Run Text="框选区域翻译"/><LineBreak/>
                                <Run Text="&#x2022; 单击右键"/>
                                <Run Text=" → " Foreground="{StaticResource AccentBrush}"/>
                                <Run Text="关闭翻译区域"/><LineBreak/>
                                <Run Text="&#x2022; 单击中键"/>
                                <Run Text=" → " Foreground="{StaticResource AccentBrush}"/>
                                <Run Text="切换翻译显示/隐藏"/>
                            </TextBlock>

                            <TextBlock x:Name="TxtStatus" Text="就绪 - 右键拖拽任意区域即可翻译"
                                       FontSize="12" Foreground="{StaticResource TextTertiaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- 覆盖层设置 -->
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="覆盖层设置" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}" Margin="0,0,0,12"/>

                            <!-- 透明度 -->
                            <Grid Margin="0,0,0,10">
                                <TextBlock Text="透明度" FontSize="12" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtOpacityValue" Text="85%"
                                           FontSize="12" Foreground="{StaticResource TextTertiaryBrush}"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <Slider x:Name="SliderOpacity" Minimum="10" Maximum="100" Value="85"
                                    TickFrequency="5" IsSnapToTickEnabled="True"
                                    ValueChanged="SliderOpacity_ValueChanged" Margin="0,0,0,12"/>

                            <!-- 字体大小 -->
                            <Grid Margin="0,0,0,10">
                                <TextBlock Text="字体大小" FontSize="12" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtFontSizeValue" Text="14pt"
                                           FontSize="12" Foreground="{StaticResource TextTertiaryBrush}"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <Slider x:Name="SliderFontSize" Minimum="8" Maximum="36" Value="14"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    ValueChanged="SliderFontSize_ValueChanged" Margin="0,0,0,12"/>

                            <!-- 字体颜色 -->
                            <Grid Margin="0,0,0,10">
                                <TextBlock Text="字体颜色" FontSize="12" VerticalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <RadioButton x:Name="RadioWhite" Content="白色" IsChecked="True"
                                                 GroupName="FontColor" Margin="8,0"
                                                 Foreground="{StaticResource TextSecondaryBrush}"
                                                 Checked="FontColor_Changed"/>
                                    <RadioButton x:Name="RadioYellow" Content="黄色"
                                                 GroupName="FontColor" Margin="0,0,8,0"
                                                 Foreground="{StaticResource TextSecondaryBrush}"
                                                 Checked="FontColor_Changed"/>
                                    <RadioButton x:Name="RadioCyan" Content="青色"
                                                 GroupName="FontColor"
                                                 Foreground="{StaticResource TextSecondaryBrush}"
                                                 Checked="FontColor_Changed"/>
                                </StackPanel>
                            </Grid>

                            <!-- 背景底色 -->
                            <Grid Margin="0,0,0,4">
                                <TextBlock Text="显示背景底色" FontSize="12" VerticalAlignment="Center"/>
                                <CheckBox x:Name="ChkShowBackground" IsChecked="True"
                                          HorizontalAlignment="Right" VerticalAlignment="Center"
                                          Checked="ChkShowBackground_Changed" Unchecked="ChkShowBackground_Changed"/>
                            </Grid>

                            <!-- 在线翻译 -->
                            <Grid Margin="0,4,0,4">
                                <TextBlock Text="在线翻译补全" FontSize="12" VerticalAlignment="Center"/>
                                <CheckBox x:Name="ChkOnlineTranslation" IsChecked="True"
                                          HorizontalAlignment="Right" VerticalAlignment="Center"
                                          Checked="ChkOnlineTranslation_Changed" Unchecked="ChkOnlineTranslation_Changed"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- 已翻译区域 -->
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="已翻译区域" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}" Margin="0,0,0,8"/>

                            <ItemsControl x:Name="RegionList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource SurfaceBrush}" CornerRadius="6"
                                                Padding="10,6" Margin="0,0,0,6">
                                            <Grid>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock FontSize="12" FontWeight="Medium">
                                                        <Run Text="区域 "/><Run Text="{Binding Id, Mode=OneWay}"/>
                                                    </TextBlock>
                                                    <TextBlock FontSize="11" Foreground="{StaticResource TextTertiaryBrush}">
                                                        <Run Text="{Binding Words.Count, Mode=OneWay}"/><Run Text=" 个单词"/>
                                                    </TextBlock>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                    <Button Content="👁" Width="32" Height="28" FontSize="12"
                                                            Background="{StaticResource SurfaceBrush}"
                                                            Tag="{Binding Id}" Click="BtnToggleRegion_Click"
                                                            Padding="0" Margin="0,0,4,0"/>
                                                    <Button Content="✕" Width="32" Height="28" FontSize="12"
                                                            Background="#CC3333" Tag="{Binding Id}"
                                                            Click="BtnCloseRegion_Click" Padding="0"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock x:Name="TxtNoRegions" Text="暂无翻译区域"
                                       FontSize="12" Foreground="{StaticResource TextTertiaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- 底部状态栏 -->
            <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" CornerRadius="0,0,12,12">
                <Grid Margin="16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse x:Name="OcrStatusDot" Width="8" Height="8" Fill="#2ECC71" Margin="0,0,6,0"
                                 VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtOcrStatus" Text="OCR 就绪"
                                   FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock x:Name="TxtTermCount" Text="术语: 0 | 词典: 0"
                               FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"
                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
