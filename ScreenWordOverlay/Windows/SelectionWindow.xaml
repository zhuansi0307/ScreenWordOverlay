<Window x:Class="ScreenWordOverlay.Windows.SelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="区域选择"
        WindowStyle="None"
        AllowsTransparency="True"
        Topmost="True"
        ShowInTaskbar="False"
        IsHitTestVisible="False"
        ResizeMode="NoResize"
        Background="Transparent"
        WindowState="Maximized">

    <Canvas x:Name="SelectionCanvas">
        <!-- 全屏半透明遮罩 -->
        <Rectangle x:Name="OverlayMask"
                   Fill="#33000000"
                   Width="{Binding ActualWidth, ElementName=SelectionCanvas}"
                   Height="{Binding ActualHeight, ElementName=SelectionCanvas}" />

        <!-- 选区矩形 -->
        <Rectangle x:Name="SelectionRect"
                   Fill="Transparent"
                   Stroke="#FF0078D4"
                   StrokeThickness="2"
                   StrokeDashArray="4,2"
                   Visibility="Collapsed" />

        <!-- 选区尺寸标签 -->
        <Border x:Name="SizeLabel"
                Background="#CC0078D4"
                CornerRadius="3"
                Padding="6,2"
                Visibility="Collapsed">
            <TextBlock x:Name="SizeText"
                       Foreground="White"
                       FontSize="11"
                       FontFamily="Microsoft YaHei UI" />
        </Border>
    </Canvas>
</Window>
